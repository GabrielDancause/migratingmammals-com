---
import BaseHead from '../layouts/BaseHead.astro';

// Tools 
const tools = [
  { emoji: "🛂", name: "Schengen 90/180 Calculator", slug: "/schengen-calculator", desc: "Track your days in the Schengen zone. Visual timeline of your allowance" },
  { emoji: "🌐", name: "Timezone Overlap Finder", slug: "/timezone-overlap", desc: "Find the best meeting hours between any two cities instantly" },
  { emoji: "💱", name: "Offline Currency Converter", slug: "/currency-converter", desc: "Convert 50+ currencies and crypto. Works fully offline" },
  { emoji: "✈️", name: "Travel Budget Planner", slug: "/travel-budget", desc: "Plan budgets by destination with daily and total estimates" },
  { emoji: "✈️", name: "Flight Time Calculator", slug: "/flight-time", desc: "Calculate flight time between airports with wind adjustments" },
  { emoji: "🧳", name: "Smart Packing List", slug: "/packing-list", desc: "Customized packing list based on climate and activities" },
  { emoji: "📞", name: "International Dialing Codes", slug: "/dialing-codes", desc: "Search country dialing codes and emergency numbers" },
  { emoji: "📏", name: "Distance Calculator", slug: "/distance-calculator", desc: "Calculate distance between locations with driving time" },
  { emoji: "💰", name: "Cost of Living Comparator", slug: "/cost-of-living", desc: "Compare living costs between two cities" },
  { emoji: "🧾", name: "Trip Expense Splitter", slug: "/expense-splitter", desc: "Split group expenses fairly across multiple currencies" },
  { emoji: "🧮", name: "Digital Nomad Tax Estimator", slug: "/nomad-tax", desc: "Estimate tax obligations by residency and income sources" },
  { emoji: "⏳", name: "Trip Countdown Timer", slug: "/trip-countdown", desc: "Track countdowns for multiple upcoming trips" },
  { emoji: "🛂", name: "Visa Requirement Checker", slug: "/visa-checker", desc: "Check visa requirements based on passport and destination" },
  { emoji: "🕐", name: "World Clock Dashboard", slug: "/world-clock", desc: "View current time in multiple cities with business hours" },
  { emoji: "😴", name: "Jet Lag Calculator", slug: "/jet-lag", desc: "Personalized recovery schedule to adjust to new timezone" },
  { emoji: "🔌", name: "Travel Power Adapter Guide", slug: "/power-adapter", desc: "Check plug types, voltage, and frequency by country" },
  { emoji: "🕐", name: "Timezone Converter", slug: "/timezone-converter", desc: "Convert times between timezones with DST support" },
  { emoji: "✈️", name: "Airport Code Lookup", slug: "/airport-codes", desc: "Search 5,000+ IATA/ICAO airport codes worldwide" },
  { emoji: "🗣️", name: "Travel Language Phrases", slug: "/language-phrases", desc: "Essential phrases in 20+ languages with pronunciation" },
  { emoji: "✅", name: "Travel Checklist Generator", slug: "/travel-checklist", desc: "Customized pre-trip checklist for any destination" }
];

// Studies 
const studies = [
  { title: "Travel Credit Card Foreign Transaction Fee Comparison 2026", subtitle: "24 items · best travel cards", slug: "/travel-card-fees", stat: "0%", statLabel: "foreign transaction fee (best cards)", desc: "Compared 24 top travel credit cards to find the best perks and lowest fees. The top cards offer 0% foreign transaction fees and strong rewards.", tag: "ORIGINAL RESEARCH" },
  { title: "Digital Nomad Cost of Living Index 2026", subtitle: "42 items · most popular cities", slug: "/cost-of-living-index", stat: "$894", statLabel: "Chiang Mai monthly budget", desc: "Compile cost of living data for 42 popular digital nomad cities. The cheapest city, Da Nang, costs just $870/mo.", tag: "ORIGINAL RESEARCH" },
  { emoji: "🏢", name: "Coworking Space Prices Around the World 2026", slug: "/coworking-prices", desc: "Compare coworking day pass and monthly prices across 50+ cities popular with digital nomads.", stat: "52", statLabel: "cities analyzed" },
  { emoji: "🌍", name: "Digital Nomad Visa Index 2026", slug: "/nomad-visa-index", desc: "60 countries with nomad visa programs — cost, duration, tax implications", stat: "60", statLabel: "countries with nomad visas" }
];

// Guides
const guides = [
  { emoji: "🇪🇺", name: "Schengen 90/180 Guide", slug: "/guide-schengen", desc: "Complete guide to the Schengen rule with calculation tips" },
  { emoji: "🛡️", name: "Travel Insurance Guide", slug: "/guide-travel-insurance", desc: "Compare SafetyWing, World Nomads, Genki for nomads" },
  { emoji: "💻", name: "Coworking Spaces Guide", slug: "/guide-coworking", desc: "How to choose coworking spaces with day pass tips" },
  { emoji: "🛂", name: "Remote Work Visas by Country", slug: "/guide-remote-work-visa", desc: "Visa requirements, costs, and application tips" },
  { emoji: "🐢", name: "Slow Travel Guide", slug: "/guide-slow-travel", desc: "Why month-long stays beat city hopping" }
];

// Lists
const lists = [
  { emoji: "🏙️", name: "Best Digital Nomad Cities", slug: "/list-nomad-cities", desc: "Top cities ranked by cost, internet, community, safety" },
  { emoji: "💳", name: "Best Travel Credit Cards", slug: "/list-travel-credit-cards", desc: "No-FX-fee cards with lounges and insurance" },
  { emoji: "📱", name: "Essential Travel Apps", slug: "/list-travel-apps", desc: "Maps, translation, flights, safety, expense tracking" },
  { emoji: "📡", name: "Best eSIM Providers", slug: "/list-esim", desc: "Global data plans compared for travelers" },
  { emoji: "🔒", name: "Best VPN Services", slug: "/list-vpn", desc: "VPN comparison for travelers and nomads" }
];
---
<html lang="en">
<head>
  <BaseHead />
  <title>migratingmammals.com — Digital Nomad Tools & Research</title>
  <meta name="description" content="Free tools for digital nomads and travelers. Schengen tracker, timezone overlap finder, cost of living comparison, visa guides, and travel research." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, sans-serif; 
      background: #060a12; 
      color: #c8d0de; 
      line-height: 1.6;
    }

    /* Hero */
    .hero { 
      text-align: center; 
      padding: 100px 24px 70px; 
      background: linear-gradient(180deg, #1a0f08 0%, #060a12 100%); 
      position: relative; 
    }
    .hero::before { 
      content: ''; 
      position: absolute; 
      inset: 0; 
      background: radial-gradient(circle at 50% 40%, rgba(196,149,106,0.08) 0%, transparent 60%); 
    }
    .hero-content { position: relative; z-index: 1; }
    .hero .tagline { 
      color: #C4956A; 
      font-size: 0.85rem; 
      font-weight: 700; 
      letter-spacing: 3px; 
      text-transform: uppercase; 
      margin-bottom: 16px; 
    }
    .hero h1 { 
      font-size: 3rem; 
      font-weight: 900; 
      letter-spacing: -1.5px; 
      margin-bottom: 20px; 
      color: #fff;
    }
    .hero p { 
      color: #5a6a80; 
      font-size: 1.05rem; 
      max-width: 520px; 
      margin: 0 auto; 
    }

    /* Sections */
    .section-container { 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 60px 24px; 
    }
    .section-header { 
      text-align: center; 
      margin-bottom: 40px; 
    }
    .section-tag { 
      display: inline-block; 
      background: rgba(196,149,106,0.1); 
      color: #C4956A; 
      font-size: 0.7rem; 
      font-weight: 800; 
      padding: 6px 16px; 
      border-radius: 20px; 
      letter-spacing: 1px; 
      margin-bottom: 12px; 
    }
    .section-title { 
      font-size: 2.2rem; 
      font-weight: 900; 
      color: #fff; 
      margin-bottom: 8px; 
      letter-spacing: -0.8px; 
    }
    .section-sub { 
      color: #5a6a80; 
      font-size: 1rem; 
    }

    /* Tools Grid */
    .tools-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 16px; 
    }
    .tool-card { 
      background: #0f1115; 
      border: 1px solid #2a2418; 
      border-radius: 12px; 
      padding: 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .tool-card:hover { 
      border-color: #C4956A; 
      transform: translateY(-2px); 
    }
    .tool-emoji { 
      font-size: 1.4rem; 
      margin-bottom: 8px; 
      display: block; 
    }
    .tool-name { 
      font-size: 0.95rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .tool-desc { 
      font-size: 0.8rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Studies Grid */
    .studies-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
      gap: 24px; 
    }
    .study-card { 
      background: linear-gradient(135deg, #110e0a 0%, #1a150e 100%); 
      border: 1px solid #2a2418; 
      border-radius: 16px; 
      padding: 28px 24px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.3s ease; 
      position: relative; 
      overflow: hidden; 
    }
    .study-card::before { 
      content: ''; 
      position: absolute; 
      top: 0; 
      left: 0; 
      right: 0; 
      height: 2px; 
      background: linear-gradient(90deg, #C4956A, #D4A57A); 
      opacity: 0; 
      transition: opacity 0.3s; 
    }
    .study-card:hover { 
      border-color: #C4956A; 
      transform: translateY(-3px); 
      box-shadow: 0 12px 40px rgba(196,149,106,0.15); 
    }
    .study-card:hover::before { opacity: 1; }
    
    .study-emoji { 
      font-size: 1.6rem; 
      margin-bottom: 12px; 
      display: block; 
    }
    .study-stat { 
      margin-bottom: 16px; 
    }
    .stat-number { 
      display: block; 
      font-size: 2rem; 
      font-weight: 900; 
      color: #C4956A; 
      line-height: 1; 
      letter-spacing: -1px; 
    }
    .stat-label { 
      display: block; 
      font-size: 0.75rem; 
      color: #5a6a80; 
      margin-top: 4px; 
    }
    .study-name { 
      font-size: 1rem; 
      font-weight: 800; 
      color: #e0e8f0; 
      margin-bottom: 8px; 
      line-height: 1.3; 
    }
    .study-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Guides & Lists Grid */
    .guides-grid, .lists-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
      gap: 20px; 
    }
    .guide-card, .list-card { 
      background: #0f1115; 
      border: 1px solid #2a2418; 
      border-radius: 14px; 
      padding: 24px 20px; 
      text-decoration: none; 
      color: inherit; 
      display: block; 
      transition: all 0.2s ease; 
    }
    .guide-card:hover, .list-card:hover { 
      border-color: #C4956A; 
      transform: translateY(-2px); 
    }
    .guide-emoji, .list-emoji { 
      font-size: 1.5rem; 
      margin-bottom: 10px; 
      display: block; 
    }
    .guide-name, .list-name { 
      font-size: 1rem; 
      font-weight: 700; 
      color: #e0e8f0; 
      margin-bottom: 6px; 
    }
    .guide-desc, .list-desc { 
      font-size: 0.85rem; 
      color: #6a7a90; 
      line-height: 1.4; 
    }

    /* Footer */
    .footer { 
      text-align: center; 
      padding: 50px 24px; 
      font-size: 0.85rem; 
      color: #3a4a5a; 
      border-top: 1px solid #151f2e; 
      background: #040810; 
    }
    .footer a { 
      color: #C4956A; 
      text-decoration: none; 
    }
    .footer a:hover { 
      text-decoration: underline; 
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .hero { padding: 70px 20px 50px; }
      .section-container { padding: 40px 20px; }
      .tools-grid, .studies-grid, .guides-grid, .lists-grid { 
        grid-template-columns: 1fr; 
      }
    }
  </style>
</head>
<body>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Digital Nomad Tools & Research</div>
      <h1>migratingmammals.com</h1>
      <p>Research & tools for people who move — and the places that host them.</p>
    </div>
  </div>

  <!-- Tools Section -->
  {tools.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🛠️ TOOLS</span>
        <h2 class="section-title">Nomad Tools</h2>
        <p class="section-sub">Free, runs in your browser, no signup.</p>
      </div>
      <div class="tools-grid">
        {tools.map(tool => (
          <a class="tool-card" href={tool.slug}>
            <span class="tool-emoji">{tool.emoji}</span>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Studies Section -->
  {studies.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">🔬 RESEARCH</span>
        <h2 class="section-title">Featured Studies</h2>
        <p class="section-sub">Real data for real nomads. Scraped, compared, ranked.</p>
      </div>
      <div class="studies-grid">
        {studies.map(study => (
          <a class="study-card" href={study.slug}>
            {study.tag && <span class="section-tag" style="position: absolute; top: 20px; right: 20px; font-size: 0.6rem;">{study.tag}</span>}
            {study.emoji && <span class="study-emoji">{study.emoji}</span>}
            <div class="study-stat">
              <span class="stat-number">{study.stat}</span>
              <span class="stat-label">{study.statLabel}</span>
            </div>
            <h3 class="study-name">{study.title || study.name}</h3>
            {study.subtitle && <p style="font-size: 0.8rem; color: #C4956A; margin-bottom: 8px;">{study.subtitle}</p>}
            <p class="study-desc">{study.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Guides Section -->
  {guides.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📚 GUIDES</span>
        <h2 class="section-title">Travel Guides</h2>
        <p class="section-sub">Comprehensive guides for nomads and travelers.</p>
      </div>
      <div class="guides-grid">
        {guides.map(guide => (
          <a class="guide-card" href={guide.slug}>
            <span class="guide-emoji">{guide.emoji}</span>
            <h3 class="guide-name">{guide.name}</h3>
            <p class="guide-desc">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Lists Section -->
  {lists.length > 0 && (
    <div class="section-container">
      <div class="section-header">
        <span class="section-tag">📋 LISTS</span>
        <h2 class="section-title">Curated Lists</h2>
        <p class="section-sub">Best apps, services, and destinations for nomads.</p>
      </div>
      <div class="lists-grid">
        {lists.map(list => (
          <a class="list-card" href={list.slug}>
            <span class="list-emoji">{list.emoji}</span>
            <h3 class="list-name">{list.name}</h3>
            <p class="list-desc">{list.desc}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Footer -->
  <div class="footer">
    © 2026 <a href="/">migratingmammals.com</a> · A <a href="https://gab.ae">GAB Ventures</a> property
  </div>
</body>
</html>